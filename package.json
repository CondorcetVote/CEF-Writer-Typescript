{
  "name": "cef-writer",
  "version": "0.1.0",
  "description": "Streaming TypeScript writer that produces valid Condorcet Election Format (CEF) documents line by line. A faithful port of CondorcetVote/CEF-Writer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "node": "./dist/index.node.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.browser.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "prepublish": "npm run lint && npm run type-check && npm run build"
  },
  "packageManager": "bun@latest",
  "keywords": [
    "cef",
    "condorcet",
    "election",
    "condorcet-election-format",
    "voting",
    "writer",
    "typescript"
  ],
  "author": "Condorcet Vote",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CondorcetVote/CEF-Writer-Typescript.git"
  },
  "bugs": {
    "url": "https://github.com/CondorcetVote/CEF-Writer-Typescript/issues"
  },
  "homepage": "https://github.com/CondorcetVote/CEF-Writer-Typescript#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "8.61.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "_comment": {
    "dev-setup": "For development, use Bun: bun install && bun run dev",
    "runtime": "Requires Node.js 24+ (ESM, no CommonJS legacy support)",
    "users": "End users can use npm, yarn, pnpm, or bun with Node.js 24+"
  }
}
